# ====== Digiwangsa — Environment Template ======
# Salin file ini menjadi .env lalu isi nilainya. JANGAN commit .env asli.

# Database MySQL (buat user khusus di panel, jangan pakai root)
DATABASE_URL="mysql://digiwangsa_user:GANTI_PASSWORD@127.0.0.1:3306/digiwangsa"

# Secret sesi login admin — generate: openssl rand -base64 32
AUTH_SECRET=""

# URL situs produksi (dipakai sitemap, OG image, dsb)
NEXT_PUBLIC_SITE_URL="https://domainmu.com"

# Nomor WhatsApp admin (format internasional tanpa +). Bisa diubah lagi via Admin > Pengaturan
NEXT_PUBLIC_WHATSAPP="6281234567890"

# Groq API key (chat AI + AI landing generator) — https://console.groq.com
GROQ_API_KEY=""

# Email notifikasi lead (opsional — kosongkan untuk menonaktifkan; lead tetap masuk dashboard)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Digiwangsa <no-reply@digiwangsa.com>"
ADMIN_EMAIL=""
